# API
DATABASE_URL=sqlite:///./sof_ladder.db
API_HOST=127.0.0.1
API_PORT=8080
API_BASE=http://127.0.0.1:8080
BOT_API_SECRET=change-me-bot
ORCHESTRATOR_SECRET=change-me-orch

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_LADDER_CHANNEL_ID=

# Matchmaking
SERVER_CONNECT_IP=your.vps.public.ip
MATCH_OFFER_SECONDS=60
FRAGLIMIT=20
PORT_START=28910
PORT_END=28959

# SoF install (orchestrator host)
SOF_INSTALL_DIR=/opt/sof
# Folder name for +set user — data at $SOF_CWD/$SOF_USER_SUBFOLDER/, scripts in .../sofplus/addons/
SOF_USER_SUBFOLDER=user
# Gametype cvar: 4 = CTF (also set in ladder_match.cfg)
SOF_DEATHMATCH=4

# Optional overrides (leave unset to derive from SOF_INSTALL_DIR + SOF_USER_SUBFOLDER)
# SOF_EXE=/path/to/sofmp.exe
# SOF_CWD=/path/to/sof
# SOF_USER_DIR=/path/to/sof/user
# WINEPREFIX=/path/to/wineprefix
# SOF_LADDER_OUT_DIR=/path/to/user/sofplus/data/ladder_out
# SOF_LADDER_LOG_DIR=/var/log/sof-ladder

VERIFY_SERVER_PORT=28908

WINE=wine
XVFB_RUN=xvfb-run
